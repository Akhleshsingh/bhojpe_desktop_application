{
  "name": "bhojPe",
  "version": "1.0.0",
  "description": "Bhojpe Desktop Application",
  "author": "Akhlesh Kushwah",
  "private": false,
  "main": "main.cjs",
  "type": "module",
  "homepage": "./",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5000",
    "dev:react": "vite --port 5173",
    "dev:electron": "cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "dev:full": "npm-run-all --parallel dev:react dev:electron",
    "build:react": "tsc -b && vite build",
    "build:electron": "electron-builder",
    "build": "npm run build:react && npm run build:electron",
    "preelectron-pack": "npm run build:react",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:build": "electron-builder",
    "electron:win": "electron-builder --win",
    "electron:mac": "electron-builder --mac"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^6.5.0",
    "@mui/material": "^6.5.0",
    "@reduxjs/toolkit": "^2.11.2",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "axios": "^1.13.6",
    "bootstrap": "^5.3.8",
    "dayjs": "^1.11.20",
    "react": "^18.3.1",
    "react-bootstrap": "^2.10.10",
    "react-calendar": "^5.1.0",
    "react-datepicker": "^7.6.0",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.30.3",
    "recharts": "^2.15.4",
    "sweetalert2": "^11.26.22",
    "use-sound": "^4.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.28",
    "@types/react-datepicker": "^7.0.0",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "cross-env": "^7.0.3",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^5.4.21"
  }
}
